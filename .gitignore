*.local.ps1
dhan_ironcondor/.env

# Python backend
__pycache__/
*.pyc
.venv/
venv/

# Local research DB (regenerable by running backend/pipeline.py)
*.duckdb
*.duckdb.wal

# Options backtest SQLite cache (local-only, re-downloadable via
# /api/options_backtest?action=download — see api/options_backtest.py)
backend/backtest_cache.db

# Serving data (breakouts/ohlc/performance/etc.) now lives on the orphan `data`
# branch, force-pushed daily by .github/workflows/*.yml — NOT committed to main,
# which was growing ~6k files/day. Regenerate locally with `cd backend; python
# run_scan.py`. Activation (one-time, when you adopt this): `git rm -r --cached data`
# then commit, so main stops tracking the already-committed snapshot.
/data/

# Throwaway research artifacts (e.g. the G/H method exploration scratch dumps)
scratch_*

# Internal design/handoff notes — kept on disk for Fable/us to reason over, not
# committed as public repo content.
backend/OPTIONS_FLOW_TRADIER_NOTES.md

# Local scratch / verification tooling (one-off scripts, screenshots, branch dumps).
# Kept on disk but never committed: methods.py / CLAUDE.md reference a couple of these
# as ongoing cross-checks. Regenerable; nothing here is source of record.
/scratchpad/
_verify_*
_httpserver*.log

# Fable design-review scratch — throwaway HTML mockups + Playwright screenshots from a
# redesign-concept comparison pass. Regenerate by re-running the review pass; nothing
# here is source of record.
concept_*.html
concept_*_verify.png
concepts.html
_concept_review.py
_review_*.png
_payload.json

# Local scratch copies of serving data pulled while wiring the live-record join
# (breakouts/live dumps are multi-MB and belong on the orphan `data` branch, NOT
# main — see the /data/ note above). Regenerate with `cd backend; python run_scan.py`.
_check.json
_live_breakouts.json
pub_breakouts.json

# Dhan iron-condor sell-side (dhan_ironcondor/): paper-trading runtime state
# (positions/orders/event log per strategy, plus stale timestamped .bak copies)
# and the downloaded scrip-master CSV — both regenerated by
# instruments.py:download_master() / execution.py on each run, not source of record.
dhan_ironcondor/runtime/

# Stale duplicate of the scrip-master CSV, unreferenced by any code (the live
# copy lives under dhan_ironcondor/runtime/, already ignored above). Kept on
# disk pending cleanup; not committed.
dhan_ironcondor/master_sample.csv

# options_backtest/ raw NSE bhavcopy cache (~87MB, one row per contract per day) —
# too large to commit and fully regenerable via
# `python options_backtest/scripts/fetch_bhavcopy.py` (see options_backtest/REPORT.md).
# fetch_log.txt (small, per-day fetch audit trail) and everything under output/ ARE
# committed as the source-of-record results.
options_backtest/data/nifty_fo_daily.csv

.vercel
.env*

# Dhan price-source caches (backend/): local, regenerable — never commit. The
# token cache holds a LIVE access token (credential); the scrip map is rebuilt
# from Dhan's scrip-master download by dhan_scrip.py.
backend/.dhan_token_cache.json
backend/.dhan_scrip_map.json
