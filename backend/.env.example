# Ask AI tries backends in this order, skipping any whose key isn't set below, and falls
# through to the next one on a rate limit, quota, or outage. Only GROQ_API_KEY is required
# for the feature to work at all (it also powers web_search, which is Groq-only for now);
# DEEPSEEK_API_KEY / GEMINI_API_KEY / CEREBRAS_API_KEY / NVIDIA_NIM_API_KEY are optional
# extra fallback tiers, each on its own separate rate-limit quota.
GROQ_API_KEY=gsk_your_key_here
# Free key: https://console.groq.com/keys

DEEPSEEK_API_KEY=
# Key (paid, but very cheap): https://platform.deepseek.com/api_keys

GEMINI_API_KEY=
# Free key: https://aistudio.google.com/apikey

CEREBRAS_API_KEY=
# Free key: https://cloud.cerebras.ai

NVIDIA_NIM_API_KEY=
# Free key (200 req/day): https://build.nvidia.com

# Optional model overrides (each defaults sensibly if unset):
# GROQ_MODEL=llama-3.3-70b-versatile     # 1st in the main chain (best reasoning)
# GEMINI_MODEL=gemini-2.5-flash          # 2nd -- verified solid at multi-step tool chaining
# CEREBRAS_MODEL=gpt-oss-120b            # 3rd -- larger cousin of GROQ_MODEL_3 below, on a
                                          # quota pool entirely separate from Groq/Gemini
# NVIDIA_NIM_MODEL=deepseek-ai/deepseek-v4-flash  # 4th -- same model as DEEPSEEK_MODEL below,
                                          # but free via NIM (no funded balance required)
# GROQ_MODEL_3=openai/gpt-oss-20b        # 5th -- separate Groq budget from GROQ_MODEL
# GROQ_MODEL_2=llama-3.1-8b-instant      # 6th (last Groq option) -- weakest at chaining
                                          # multiple tool calls; kept last on purpose
# DEEPSEEK_MODEL=deepseek-v4-flash       # 7th/last -- NOTE: deepseek-chat deprecates
                                          # 2026-07-24, don't use it
# GROQ_SEARCH_MODEL=groq/compound        # backs web_search, 1st try -- separate budget
                                          # from GROQ_MODEL (llama-4-scout + gpt-oss-120b)
# GROQ_SEARCH_MODEL_2=groq/compound-mini # web_search 2nd try -- NOTE shares its budget
                                          # with GROQ_MODEL (both use llama-3.3-70b-versatile)
# GEMINI_SEARCH_MODEL=gemini-2.5-flash   # web_search LAST resort -- Gemini's own Google
                                          # Search grounding (separate API + quota from
                                          # everything else; used automatically if the
                                          # Groq search chain above fails and GEMINI_API_KEY
                                          # is set)
# PORT=8010

# --- News (optional; backend/fetch_news.py) -----------------------------------------
# None are required for the site to work -- stocks just show no News card without any
# of them. Sentiment is computed locally (backend/sentiment.py) from whichever
# provider's headlines are cached, so it doesn't depend on a specific one of these.
# Finnhub is deliberately not used: its free tier is US-only for company news/sentiment
# (international coverage needs a paid Premium plan), so it can't cover NSE/BSE names
# for free despite its generous 60 calls/min rate limit.
# Priority order (see fetch_news.py): GNews first (spent on the most-primed/highest-
# conviction names), then Marketaux, then NewsData.io extends coverage furthest.
GNEWS_API_KEY=
# Free key (100 req/day): https://gnews.io/

MARKETAUX_API_KEY=
# Free key (~100 req/day): https://www.marketaux.com/

NEWSDATA_API_KEY=
# Free key (200 credits/day, ~12h delayed): https://newsdata.io/

# --- Social buzz (optional; backend/fetch_social.py) ---------------------------------
# Mention count + local sentiment from a fixed set of India-trading subreddits, plus a
# Google Trends search-interest score (pytrends -- unofficial, needs no key, so it runs
# automatically). StockTwits is deliberately not used: its coverage is almost entirely
# US-listed tickers, so NSE/BSE names essentially don't appear on it.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Free "script" app, no billing: https://www.reddit.com/prefs/apps -> create app ->
# choose "script" -> client_id is the string under the app name, secret is labeled "secret".

REDDIT_USER_AGENT=BreakoutAI/1.0 (social buzz fetch)
# Reddit asks for a descriptive, unique user agent -- customize the string above
# (e.g. include your Reddit username) rather than using the default verbatim.
